#!/bin/sh
# Create device nodes from sysfs
for cls in drm kgsl input sound; do
    for dev in /sys/class/$cls/*/dev; do
        [ -f "$dev" ] || continue
        read maj_min < "$dev"
        name=$(basename $(dirname "$dev"))
        case $cls in
            drm) mknod -m 0666 /dev/dri/$name c ${maj_min%:*} ${maj_min#*:} 2>/dev/null ;;
            input) mknod -m 0666 /dev/input/$name c ${maj_min%:*} ${maj_min#*:} 2>/dev/null ;;
            *) mknod -m 0666 /dev/$name c ${maj_min%:*} ${maj_min#*:} 2>/dev/null ;;
        esac
    done
done
# Write synthetic udev database for libinput
mkdir -p /run/udev/data
for dev in /sys/class/input/event*/device/name; do
    [ -f "$dev" ] || continue
    name=$(cat "$dev")
    evnum=$(basename $(dirname $(dirname "$dev")))
    read maj_min < /sys/class/input/$evnum/dev
    case "$name" in
        *focaltech*|*fts*|*touch*|*goodix*)
            printf 'E:ID_INPUT=1\nE:ID_INPUT_TOUCHSCREEN=1\nE:LIBINPUT_CALIBRATION_MATRIX=-1 0 1 0 -1 1\n' \
                > /run/udev/data/c${maj_min}
            ;;
    esac
done
# Signal readiness and stay alive
touch /run/ready/slate-hwsetup
exec sleep infinity
