#!/bin/busybox sh
# Slate OS Native Init
#
# Replaces Android's init. Loaded via init_boot partition.
# Vendor modules come from vendor_boot (merged by bootloader).
#
# Boot sequence:
#   1. Mount virtual filesystems
#   2. Load vendor kernel modules
#   3. Mount hardware partitions (vendor, firmware, data)
#   4. Prepare rootfs at /data/slate/rootfs
#   5. switch_root into Chimera Linux with arkhe pid1

set -e

# Busybox symlinks (applet mode)
/bin/busybox --install -s /bin

export PATH=/bin

log() { echo "[slate-init] $*"; }

log "Slate OS native init starting"
log "Kernel: $(uname -r)"

# -----------------------------------------------------------------------
# 1. Mount virtual filesystems
# -----------------------------------------------------------------------
mkdir -p /proc /sys /dev /tmp /run /mnt/root
mount -t proc     proc     /proc
mount -t sysfs    sysfs    /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs    tmpfs    /tmp
mount -t tmpfs    tmpfs    /run
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts -o newinstance,ptmxmode=0666

log "virtual filesystems mounted"

# -----------------------------------------------------------------------
# 2. Load vendor kernel modules
# -----------------------------------------------------------------------
MODDIR=""
for d in /lib/modules /vendor_ramdisk/lib/modules; do
    if [ -d "$d" ]; then
        MODDIR="$d"
        break
    fi
done

if [ -n "$MODDIR" ] && [ -f "$MODDIR/modules.load" ]; then
    log "loading vendor modules from $MODDIR"
    LOADED=0
    FAILED=0
    while IFS= read -r mod; do
        # Skip comments and empty lines
        case "$mod" in \#*|"") continue ;; esac
        modpath="$MODDIR/$mod"
        if [ -f "$modpath" ]; then
            if insmod "$modpath" 2>/dev/null; then
                LOADED=$((LOADED + 1))
            else
                FAILED=$((FAILED + 1))
            fi
        fi
    done < "$MODDIR/modules.load"
    log "modules: $LOADED loaded, $FAILED failed"
else
    log "WARNING: no modules.load found, trying modprobe"
    # Fallback: load critical modules by name
    for mod in msm_drm focaltech_fts wlan; do
        modprobe "$mod" 2>/dev/null || true
    done
fi

# Wait for display and touch devices to appear
sleep 1

# -----------------------------------------------------------------------
# 3. Mount hardware partitions
# -----------------------------------------------------------------------

# Find partition block devices
VENDOR_DEV=""
DATA_DEV=""
FIRMWARE_DEV=""
PERSIST_DEV=""

# Try by-name symlinks (set up by kernel/uevent)
for dev in /dev/block/by-name/vendor_a /dev/block/by-name/vendor; do
    [ -b "$dev" ] && VENDOR_DEV="$dev" && break
done

for dev in /dev/block/by-name/userdata /dev/block/by-name/data; do
    [ -b "$dev" ] && DATA_DEV="$dev" && break
done

for dev in /dev/block/by-name/modem_a /dev/block/by-name/modem; do
    [ -b "$dev" ] && FIRMWARE_DEV="$dev" && break
done

for dev in /dev/block/by-name/persist; do
    [ -b "$dev" ] && PERSIST_DEV="$dev" && break
done

# by-name may not exist yet — wait for uevent processing
if [ -z "$DATA_DEV" ]; then
    log "waiting for block devices..."
    sleep 2
    # Trigger uevent for block devices
    echo add > /sys/class/block/sda10/uevent 2>/dev/null || true
    sleep 1
    # Retry by sysfs scan
    for blk in /sys/class/block/sd*; do
        name=$(cat "$blk/device/../by-name" 2>/dev/null) || continue
    done
    # Fallback: known device paths from this tablet
    [ -z "$DATA_DEV" ]     && [ -b /dev/sda10 ] && DATA_DEV=/dev/sda10
    [ -z "$VENDOR_DEV" ]   && [ -b /dev/dm-5 ]  && VENDOR_DEV=/dev/dm-5
    [ -z "$FIRMWARE_DEV" ] && [ -b /dev/sde4 ]   && FIRMWARE_DEV=/dev/sde4
    [ -z "$PERSIST_DEV" ]  && [ -b /dev/sda2 ]   && PERSIST_DEV=/dev/sda2
fi

# Mount data partition (contains Chimera rootfs at /slate/rootfs)
mkdir -p /mnt/data
if [ -n "$DATA_DEV" ]; then
    # Data is f2fs, may need specific options
    mount -t f2fs "$DATA_DEV" /mnt/data -o noatime 2>/dev/null || \
    mount "$DATA_DEV" /mnt/data -o noatime 2>/dev/null || \
    log "ERROR: failed to mount data partition"
    log "data mounted: $DATA_DEV -> /mnt/data"
else
    log "ERROR: data partition not found"
fi

ROOTFS=/mnt/data/slate/rootfs

if [ ! -d "$ROOTFS/usr" ]; then
    log "ERROR: rootfs not found at $ROOTFS"
    log "dropping to rescue shell"
    exec /bin/sh
fi

log "rootfs found at $ROOTFS"

# -----------------------------------------------------------------------
# 4. Prepare rootfs mounts
# -----------------------------------------------------------------------

# Mount vendor for firmware blobs
mkdir -p "$ROOTFS/vendor"
if [ -n "$VENDOR_DEV" ]; then
    mount -t ext4 "$VENDOR_DEV" "$ROOTFS/vendor" -o ro 2>/dev/null || \
    mount "$VENDOR_DEV" "$ROOTFS/vendor" -o ro 2>/dev/null || true
fi

# Mount firmware partition
mkdir -p "$ROOTFS/vendor/firmware_mnt" "$ROOTFS/lib/firmware"
if [ -n "$FIRMWARE_DEV" ]; then
    mount -t vfat "$FIRMWARE_DEV" "$ROOTFS/vendor/firmware_mnt" -o ro 2>/dev/null || true
fi

# Bind-mount firmware paths so kernel can find blobs
if [ -d "$ROOTFS/vendor/firmware" ]; then
    mount --bind "$ROOTFS/vendor/firmware" "$ROOTFS/lib/firmware" 2>/dev/null || true
fi

# Mount persist for WiFi calibration data
mkdir -p "$ROOTFS/mnt/vendor/persist"
if [ -n "$PERSIST_DEV" ]; then
    mount -t ext4 "$PERSIST_DEV" "$ROOTFS/mnt/vendor/persist" -o ro 2>/dev/null || true
fi

# Set up /dev in rootfs (tmpfs because /data is nodev)
mount -t tmpfs tmpfs "$ROOTFS/dev" -o mode=0755
# Create essential device nodes from running kernel
for dev_info in "1:3 null" "1:5 zero" "1:7 full" "1:8 random" "1:9 urandom" \
                "5:0 tty" "5:2 ptmx" "10:200 net/tun" "226:0 dri/card0" \
                "226:128 dri/renderD128"; do
    maj_min="${dev_info%% *}"
    name="${dev_info##* }"
    major="${maj_min%%:*}"
    minor="${maj_min##*:}"
    dir=$(dirname "$ROOTFS/dev/$name")
    mkdir -p "$dir"
    mknod "$ROOTFS/dev/$name" c "$major" "$minor" 2>/dev/null || true
done

# Create input device nodes from sysfs
for inp in /sys/class/input/event*; do
    num="${inp##*event}"
    dev_nums=$(cat "$inp/dev" 2>/dev/null) || continue
    major="${dev_nums%%:*}"
    minor="${dev_nums##*:}"
    mkdir -p "$ROOTFS/dev/input"
    mknod "$ROOTFS/dev/input/event$num" c "$major" "$minor" 2>/dev/null || true
done

# Set up devpts
mkdir -p "$ROOTFS/dev/pts" "$ROOTFS/dev/shm"
mount -t devpts devpts "$ROOTFS/dev/pts" -o newinstance,ptmxmode=0666
mount -t tmpfs tmpfs "$ROOTFS/dev/shm"

# Symlink /dev/fd, stdin, stdout, stderr
ln -sf /proc/self/fd "$ROOTFS/dev/fd" 2>/dev/null || true
ln -sf /proc/self/fd/0 "$ROOTFS/dev/stdin" 2>/dev/null || true
ln -sf /proc/self/fd/1 "$ROOTFS/dev/stdout" 2>/dev/null || true
ln -sf /proc/self/fd/2 "$ROOTFS/dev/stderr" 2>/dev/null || true

log "rootfs prepared"

# -----------------------------------------------------------------------
# 5. switch_root into Chimera Linux
# -----------------------------------------------------------------------

# Clean up initramfs mounts that switch_root needs gone
umount /tmp 2>/dev/null || true
umount /run 2>/dev/null || true

log "switching root to $ROOTFS"

# Move virtual mounts into rootfs
mount --move /proc "$ROOTFS/proc" 2>/dev/null || mount -t proc proc "$ROOTFS/proc"
mount --move /sys "$ROOTFS/sys" 2>/dev/null || mount -t sysfs sysfs "$ROOTFS/sys"

# switch_root frees the initramfs and execs the new init
# arkhe's pid1 stub takes over as PID 1, then execs arkhd (supervisor)
# Boot chain: ABL → kernel → initramfs → switch_root → pid1 → arkhd → services
exec switch_root "$ROOTFS" /usr/sbin/pid1
